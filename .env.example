# Database connection string
DATABASE_URL=postgresql://user:pass@localhost:5432/nba_gm_simulator

# Secret for signing JWT tokens (required in production)
JWT_SECRET=generate-a-random-secret

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# Server port
PORT=3000

# Environment (development | production)
NODE_ENV=development

# Database connection pool size (default: 20)
DB_POOL_SIZE=20

# Enable SSL for database connections (auto-enabled in production except Railway internal)
DATABASE_SSL=false
